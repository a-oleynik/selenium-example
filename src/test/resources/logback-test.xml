<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console appender — preserves existing console output behaviour -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File appender — writes to build/logs/test.log (created automatically) -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>build/logs/test.log</file>
        <append>false</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Framework classes at DEBUG so driver lifecycle and step details are visible in the log -->
    <logger name="com.oleynik.gradle.selenium.example.framework" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>

